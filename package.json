{
  "name": "asteroidz",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -p \"[{name}]\" \"pnpm --filter @asteroidz/client dev\" \"pnpm --filter @asteroidz/server dev\"",
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "~5.8.0"
  }
}
